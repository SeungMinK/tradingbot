# 업비트 API (https://upbit.com/mypage/open_api_management)
# 주의: 출금 권한 절대 부여 금지, IP 제한 설정 권장
UPBIT_ACCESS_KEY=your-upbit-access-key
UPBIT_SECRET_KEY=your-upbit-secret-key

# KIS Developers (한국·미국 주식 공통, https://apiportal.koreainvestment.com)
# 한투 계좌 ID로 KIS Developers 가입 → 앱 등록 → APP Key/Secret 발급
# 한투 앱에서 "해외주식 거래 신청" + "통합증거금 서비스 신청" 필수
KIS_APP_KEY=your-kis-app-key
KIS_APP_SECRET=your-kis-app-secret
KIS_ACCOUNT_NUMBER=12345678               # 8자리
KIS_ACCOUNT_PRODUCT_CODE=01               # 상품코드 2자리 (대부분 01)
KIS_IS_PAPER=false                        # 모의투자=true, 실전=false

# Slack 알림 (Bot Token 방식)
# https://api.slack.com/apps → Bot User OAuth Token
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_CHANNEL=#your-channel-name

# 봇 설정
BOT_COIN=KRW-BTC
BOT_LOG_LEVEL=INFO

# DB 경로
DB_PATH=data/cryptobot.db

# JWT 시크릿 (프로덕션에서는 반드시 변경)
JWT_SECRET=cryptobot-dev-secret-change-in-production

# LLM (Claude Haiku 권장)
# https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-your-api-key
# 모델 변경 시 여기서 수정 (기본: claude-haiku-4-5-20251001)
# LLM_MODEL=claude-haiku-4-5-20251001